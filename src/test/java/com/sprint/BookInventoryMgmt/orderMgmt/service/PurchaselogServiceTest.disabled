package com.sprint.BookInventoryMgmt.ordermgmt.service;


import com.sprint.BookInventoryMgmt.ordermgmt.dto.requestDto.PurchaseLogRequestDTO;
import com.sprint.BookInventoryMgmt.ordermgmt.dto.responseDto.PurchaseLogResponseDTO;
import com.sprint.BookInventoryMgmt.ordermgmt.exceptions.PurchaseNotFoundException;

import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;

import java.util.List;

import static org.junit.jupiter.api.Assertions.*;

@SpringBootTest
class PurchaseLogServiceTest {

    @Autowired
    private IPurchaseLogService service;

    // ================= POSITIVE =================

    @Test
    void testAddPurchase() {
        PurchaseLogRequestDTO dto = new PurchaseLogRequestDTO();
        dto.setUserId(1L);
        dto.setInventoryId(100L);

        PurchaseLogResponseDTO res = service.addPurchase(dto);

        assertNotNull(res);
    }

    @Test
    void testGetAll() {
        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(2L);
            setInventoryId(200L);
        }});

        assertFalse(service.getAll().isEmpty());
    }

    @Test
    void testDeleteSuccess() {
        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(3L);
            setInventoryId(300L);
        }});

        String result = service.delete(3L);

        assertTrue(result.contains("Deleted"));
    }

    @Test
    void testMultipleInsert() {
        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(4L);
            setInventoryId(400L);
        }});

        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(5L);
            setInventoryId(500L);
        }});

        assertTrue(service.getAll().size() >= 2);
    }

    @Test
    void testMapping() {
        PurchaseLogResponseDTO res = service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(6L);
            setInventoryId(600L);
        }});

        assertEquals(600L, res.getInventoryId());
    }

    @Test
    void testGetAllNotEmpty() {
        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(7L);
            setInventoryId(700L);
        }});

        assertFalse(service.getAll().isEmpty());
    }

    @Test
    void testDeleteFlow() {
        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(8L);
            setInventoryId(800L);
        }});

        service.delete(8L);

        assertThrows(PurchaseNotFoundException.class,
                () -> service.delete(8L));
    }

    // ================= NEGATIVE =================

    @Test
    void testDeleteNotFound() {
        assertThrows(PurchaseNotFoundException.class,
                () -> service.delete(999L));
    }

    @Test
    void testAddNull() {
        assertThrows(Exception.class, () -> service.addPurchase(null));
    }

    @Test
    void testAddInvalidDTO() {
        assertThrows(Exception.class,
                () -> service.addPurchase(new PurchaseLogRequestDTO()));
    }

    @Test
    void testDeleteNull() {
        assertThrows(Exception.class, () -> service.delete(null));
    }

    @Test
    void testGetAllEmptyCheck() {
        assertNotNull(service.getAll());
    }

    @Test
    void testDeleteTwice() {
        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(10L);
            setInventoryId(1000L);
        }});

        service.delete(10L);

        assertThrows(PurchaseNotFoundException.class,
                () -> service.delete(10L));
    }

    @Test
    void testDuplicateUserId() {
        service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(11L);
            setInventoryId(1100L);
        }});

        PurchaseLogResponseDTO res = service.addPurchase(new PurchaseLogRequestDTO(){{
            setUserId(11L);
            setInventoryId(1200L);
        }});

        assertEquals(1200L, res.getInventoryId());
    }

    // ================= EDGE =================

    @Test
    void testEdgeCase() {
        assertTrue(service.getAll().size() >= 0);
    }
}